# Copy to .env for local runs. NEVER commit the real .env.
# docker-compose.yml sets these for the containerised app; these are for running
# the jar directly (java -jar) against your own MySQL.

DB_URL=jdbc:mysql://localhost:3306/hospital?useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=hospital
DB_PASSWORD=hospital

# Must be >= 32 bytes for HS256. Generate a long random value in production.
APP_JWT_SECRET=change-me-in-prod-please-use-a-long-random-secret-key
APP_JWT_EXPIRATION_MS=3600000

SERVER_PORT=8080
